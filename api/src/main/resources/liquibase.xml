    <changeSet id="reportbuilder-20260220-01-indicator-recreate" author="slubwama">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="report_builder_indicator"/>
            </not>
        </preConditions>

        <createTable tableName="report_builder_indicator">

            <column name="report_builder_indicator_id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- OpenMRS Metadata Fields -->
            <column name="uuid" type="VARCHAR(38)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="TEXT"/>

            <column name="retired" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="retire_reason" type="VARCHAR(255)"/>
            <column name="retired_by" type="INT"/>
            <column name="date_retired" type="DATETIME"/>

            <column name="creator" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="date_created" type="DATETIME">
                <constraints nullable="false"/>
            </column>

            <column name="changed_by" type="INT"/>
            <column name="date_changed" type="DATETIME"/>

            <!-- Business Fields -->
            <column name="code" type="VARCHAR(100)"/>
            <column name="kind" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="default_value_type" type="VARCHAR(20)" defaultValue="NUMBER">
                <constraints nullable="false"/>
            </column>

            <!-- New fields -->
            <column name="theme_uuid" type="VARCHAR(38)"/>

            <column name="config_json" type="LONGTEXT">
                <constraints nullable="false"/>
            </column>

            <!-- Store executable SQL explicitly -->
            <column name="sql_template" type="LONGTEXT"/>

            <!-- Optional denominator SQL -->
            <column name="denominator_sql_template" type="LONGTEXT"/>

            <column name="meta_json" type="LONGTEXT"/>

        </createTable>

        <!-- Indexes -->
        <createIndex indexName="idx_report_builder_indicator_uuid" tableName="report_builder_indicator">
            <column name="uuid"/>
        </createIndex>

        <createIndex indexName="idx_report_builder_indicator_code" tableName="report_builder_indicator">
            <column name="code"/>
        </createIndex>

        <createIndex indexName="idx_report_builder_indicator_kind" tableName="report_builder_indicator">
            <column name="kind"/>
        </createIndex>

        <createIndex indexName="idx_report_builder_indicator_theme_uuid" tableName="report_builder_indicator">
            <column name="theme_uuid"/>
        </createIndex>

        <addUniqueConstraint tableName="report_builder_indicator" columnNames="code" constraintName="uq_report_builder_indicator_code"/>
    </changeSet>


