            <!-- NEW: Report Type -->
            <column name="report_type" type="VARCHAR(30)" defaultValue="AGGREGATE">
                <constraints nullable="false"/>
            </column>

            <!-- NEW: Category -->
            <column name="category_id" type="INT"/>

            <column name="config_json" type="LONGTEXT"/>

            <column name="meta_json" type="LONGTEXT"/>

