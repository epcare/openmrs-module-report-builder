                referencedColumnNames="user_id"
                constraintName="fk_report_builder_report_changed_by"/>

        <addForeignKeyConstraint
                baseTableName="report_builder_report"
                baseColumnNames="retired_by"
                referencedTableName="users"
                referencedColumnNames="user_id"
                constraintName="fk_report_builder_report_retired_by"/>

        <!-- NEW FK: Category -->
        <addForeignKeyConstraint
                baseTableName="report_builder_report"
                baseColumnNames="category_id"
                referencedTableName="report_builder_report_category"
                referencedColumnNames="report_builder_report_category_id"
                constraintName="fk_report_builder_report_category"/>

        <!-- ================= INDEXES ================= -->

        <createIndex tableName="report_builder_report" indexName="idx_report_builder_report_uuid" unique="true">
            <column name="uuid"/>
