<?xml version="1.0" encoding="UTF-8"?>

<module configVersion="1.2">
	
	<!-- Base Module Properties -->
	<id>${project.parent.artifactId}</id>
	<name>${project.parent.name}</name>
	<version>${project.parent.version}</version>
	<package>org.openmrs.module.reportbuilder</package>
	<author>lubwamasamuel</author>
	<description>
			${project.parent.description}
	</description>

	<activator>org.openmrs.module.reportbuilder.ReportBuilderActivator</activator>
	
	<!-- <updateURL>https://modules.openmrs.org/modules/download/@MODULE_ID@/update.rdf</updateURL> -->
	<!-- /Base Module Properties -->
	
	<require_version>${openmrsPlatformVersion}</require_version>
	
	<!-- Extensions -->
	<require_modules>
		<require_module>
			org.openmrs.module.reporting
		</require_module>
		<require_module>
			org.openmrs.module.serialization.xstream
		</require_module>
		<require_module>
			org.openmrs.module.legacyui
		</require_module>
		<require_module>
			org.openmrs.module.reportingcompatibility
		</require_module>
		<require_module>
			org.openmrs.module.webservices.rest
		</require_module>
	</require_modules>

	<aware_of_modules>
		<aware_of_module>org.openmrs.module.legacyui</aware_of_module>
	</aware_of_modules>

	<globalProperty>
		<property>reportbuilder.reports.directory</property>
		<defaultValue>configuration/reportbuilder</defaultValue>
		<description>
			The path to the working directory of the report builder
		</description>
	</globalProperty>

	<globalProperty>
		<!-- Serializer whitelist global property -->
		<property>${project.parent.artifactId}.serializer.whitelist.types</property>

		<!-- Comma-separated list of fully qualified classes that XStream should be allowed to deserialize -->
		<defaultValue>
			org.openmrs.module.reportbuilder.**
		</defaultValue>

		<description>
			Whitelist reportbuilder classes for XStream deserialization (TRUNK-6188)
		</description>
	</globalProperty>
	
